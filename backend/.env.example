# ─────────────────────────────────────────
# NazAQ Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────

# Supabase (get from supabase.com → project → settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# JWT Secret — generate a random 64-char string
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Encryption key for sensitive fields (ID numbers)
# Must be exactly 32 characters
ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_KEY_HERE____

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed origins
# Add your GitHub Pages URL and any other frontends
ALLOWED_ORIGINS=https://YOUR_USERNAME.github.io,http://localhost:3000

# Admin credentials (for first login — change after first use)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123!
